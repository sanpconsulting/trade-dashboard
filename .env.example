# LLM API URL
# Points to your local LLaMA container (e.g. Ollama, vLLM, llama.cpp server)
# Use 'http://llama:11434/api/generate' if using the provided docker-compose with Ollama
LLM_API_URL="http://llama:11434/api/generate"

# The specific model name loaded in your LLaMA container
LLM_MODEL_NAME="llama3"

# Broker API Configuration (Binance)
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ENVIRONMENT=practice

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
